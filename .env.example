# Copy to .env and fill in. Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here
# Model id — the -latest alias tracks the current flash and won't retire on you.
GEMINI_MODEL=gemini-flash-latest
# Crowd-density fraction (0-1) at which a zone is flagged for action
CROWD_ALERT_THRESHOLD=0.80
